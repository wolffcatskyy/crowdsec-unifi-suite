# CrowdSec UniFi Suite — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# After starting the stack, generate credentials with:
#
#   # Create machine login for blocklist-import (read/write decisions)
#   docker exec crowdsec cscli machines add blocklist-import --password 'YourPassword'
#
#   # Create bouncer key for the sidecar (reads decisions)
#   docker exec crowdsec cscli bouncers add crowdsec-sidecar
#   # Paste the output key into BOUNCER_API_KEY below, then restart the sidecar:
#   docker compose up -d crowdsec-sidecar
#
#   # Create bouncer key for blocklist-import deduplication
#   docker exec crowdsec cscli bouncers add blocklist-import
#   # Paste the output key into BLOCKLIST_BOUNCER_KEY below

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

TZ=America/New_York

# ---------------------------------------------------------------------------
# CrowdSec
# ---------------------------------------------------------------------------

# Hostname shown in CrowdSec console and logs
CROWDSEC_HOSTNAME=crowdsec-server

# CrowdSec console enrollment key (optional — get from https://app.crowdsec.net)
CROWDSEC_ENROLL_KEY=

# ---------------------------------------------------------------------------
# CrowdSec Sidecar
# ---------------------------------------------------------------------------

# Bouncer API key for the sidecar (generated with: cscli bouncers add crowdsec-sidecar)
BOUNCER_API_KEY=your-sidecar-bouncer-key-here

# ---------------------------------------------------------------------------
# Blocklist Import — Machine Credentials
# ---------------------------------------------------------------------------

# Machine ID and password (generated with: cscli machines add blocklist-import)
BLOCKLIST_MACHINE_ID=blocklist-import
BLOCKLIST_MACHINE_PASSWORD=your-machine-password-here

# Bouncer key for deduplication (generated with: cscli bouncers add blocklist-import)
BLOCKLIST_BOUNCER_KEY=your-blocklist-bouncer-key-here

# How long imported decisions last (refreshed every INTERVAL seconds)
BLOCKLIST_DECISION_DURATION=24h

# Max decisions across all imported feeds (0 = unlimited)
# Leave at 0 when the sidecar handles capacity for your UniFi device
BLOCKLIST_MAX_DECISIONS=0

# ---------------------------------------------------------------------------
# Threat Feeds
# ---------------------------------------------------------------------------

# IPsum: aggregated threats from multiple sources (recommended)
ENABLE_IPSUM=true

# AbuseIPDB public mirror (no key needed — ~700K IPs)
ENABLE_ABUSE_IPDB=true

# Spamhaus DROP: known bad netblocks
ENABLE_SPAMHAUS=true

# Tor exit nodes (may cause false positives for legitimate users)
ENABLE_TOR=false

# Shodan/Censys scanners (noisy, use with caution)
ENABLE_SCANNERS=false

# ---------------------------------------------------------------------------
# AbuseIPDB Direct API (optional)
# ---------------------------------------------------------------------------
# The public mirror (ENABLE_ABUSE_IPDB=true above) works without a key.
# An API key gives you higher rate limits and fresher data.
# Get a free key at: https://www.abuseipdb.com/

ABUSEIPDB_API_KEY=

# Minimum confidence score for direct API queries (1-100)
ABUSEIPDB_MIN_CONFIDENCE=90

# Report malicious IPs seen on your network back to AbuseIPDB
# Applies to the sidecar (and bouncer if configured)
ABUSEIPDB_REPORT_ENABLED=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

LOG_LEVEL=INFO
